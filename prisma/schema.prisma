generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  name         String?
  grade        String?
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  nickname     String?    @unique
  qtGroup      String?
  chatLogs     ChatLog[]

  @@index([email])
  @@index([status])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  verified  Boolean  @default(false)

  @@index([email])
  @@index([code])
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String
  query     String
  response  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  isVisible Boolean  @default(true)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isPinned  Boolean  @default(false)

  @@index([createdAt])
  @@index([category])
  @@index([isPinned])
}

model SchoolMeal {
  id        String   @id @default(cuid())
  date      String
  menu      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dayOfWeek String

  @@index([date])
}

model SchoolCalendar {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  endDate   String
  eventType String
  name      String
  startDate String

  @@index([startDate])
  @@index([eventType])
}

model Timetable {
  id        String   @id @default(cuid())
  grade     String
  dayOfWeek String
  period    String
  time      String
  subject   String
  teacher   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([grade])
  @@index([grade, dayOfWeek])
}

model Post {
  id             String     @id @default(cuid())
  title          String
  content        String
  authorId       String
  authorNickname String?
  viewCount      Int        @default(0)
  isDeleted      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  comments       Comment[]
  likes          PostLike[]

  @@index([createdAt])
  @@index([authorId])
}

model Comment {
  id             String    @id @default(cuid())
  content        String
  postId         String
  authorId       String
  authorNickname String?
  parentId       String?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  parent         Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Restrict)
  replies        Comment[] @relation("CommentToComment")
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  SUSPENDED
}

model ExamSchedule {
  id        String   @id @default(cuid())
  examType  String   // MIDTERM / FINALS
  semester  String   // 1 / 2
  year      Int
  date      String   
  dayOfWeek String   
  period    Int
  time      String   
  subject   String
  grades    String[] 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examType, year, semester])
}
