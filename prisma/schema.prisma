generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Enums ============

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  SUSPENDED
}

// ============ Models ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  nickname      String?   @unique // Added nickname field
  passwordHash  String?   // bcrypt hash

  name          String?
  grade         String?   // "1", "2", ..., "12-1", "12-2"
  
  role          UserRole  @default(STUDENT)
  status        UserStatus @default(PENDING)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chatLogs      ChatLog[]

  @@index([email])
  @@index([status])
}

// verification code (6 digits, 10 min TTL)
model VerificationCode {
  id         String   @id @default(cuid())
  email      String
  code       String   // 6자리 숫자
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  verified   Boolean  @default(false)

  @@index([email])
  @@index([code])
}

// Chat logs for the WITHUS chatbot
model ChatLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query          String   @db.Text
  response       String   @db.Text
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
